# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI (server-side only — never expose to the client)
OPENAI_API_KEY=
OPENAI_MODEL_FAST=gpt-5.4-mini
OPENAI_MODEL_SUMMARY=gpt-5.4-mini
OPENAI_MODEL_SUMMARY_FALLBACK=gpt-5.4

# Resend (transactional email + non-user invite relay)
RESEND_API_KEY=

# Web Push (VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@example.com

# Cron (Bearer token for /api/cron/* — generate with: openssl rand -base64 32)
CRON_SECRET=
