# Site URL (canonical, Open Graph)
NEXT_PUBLIC_SITE_URL=https://copara.ca

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# OpenAI (server-side only — never expose to the client)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL_FAST=gpt-5.4-mini
OPENAI_MODEL_SUMMARY=gpt-5.4-mini
OPENAI_MODEL_SUMMARY_FALLBACK=gpt-5.4

# Resend (transactional email + non-user invite relay)
RESEND_API_KEY=re_your-resend-api-key
# From addresses use @copara.ca (invites@, digest@) once verified in Resend

# Web Push (VAPID)
VAPID_PUBLIC_KEY=your-vapid-public-key
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:support@copara.ca

# Cron
CRON_SECRET=your-cron-secret

# Stripe (see docs/STRIPE_SETUP.md)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_PRICE_PARENT_MONTHLY=price_your-parent-monthly-id
STRIPE_PRICE_PARENT_YEARLY=price_your-parent-yearly-id
STRIPE_PRICE_FAMILY_MONTHLY=price_your-family-monthly-id
STRIPE_PRICE_FAMILY_YEARLY=price_your-family-yearly-id
STRIPE_TRIAL_DAYS=14

# Comma-separated admin emails for staff tools (blog CMS, partner review)
COPARA_ADMIN_EMAILS=you@example.com

# Secret staff URL prefix — bookmark this; not linked from the public site. Min 8 chars, e.g. /copara-ops-8f3k2m
COPARA_STAFF_PATH=/copara-ops-change-me
